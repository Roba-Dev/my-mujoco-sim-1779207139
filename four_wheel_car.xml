<mujoco model="four_wheel_car">
  <compiler angle="radian"/>
  <option timestep="0.002" integrator="implicitfast" iterations="50"/>
  <default>
    <joint type="hinge" damping="0.5" armature="0.01"/>
    <geom type="capsule" contype="1" conaffinity="1" condim="3"/>
  </default>
  <worldbody>
    <geom name="floor" type="plane" size="20 20 0.1" condim="3"/>
    <body name="chassis" pos="0 0 0.2">
      <geom name="chassis_geom" type="box" size="0.4 0.2 0.1" rgba="0.8 0.2 0.2 1"/>
      <!-- wheels -->
      <body name="wheel_fl" pos="0.3 0.15 0">
        <joint name="wheel_fl_joint" type="hinge" axis="0 1 0" pos="0 0 0"/> 
        <geom name="wheel_fl_geom" type="cylinder" size="0.05 0.02" rgba="0.1 0.1 0.1 1" condim="3"/>
      </body>
      <body name="wheel_fr" pos="0.3 -0.15 0">
        <joint name="wheel_fr_joint" type="hinge" axis="0 1 0" pos="0 0 0"/> 
        <geom name="wheel_fr_geom" type="cylinder" size="0.05 0.02" rgba="0.1 0.1 0.1 1" condim="3"/>
      </body>
      <body name="wheel_rl" pos="-0.3 0.15 0">
        <joint name="wheel_rl_joint" type="hinge" axis="0 1 0" pos="0 0 0"/> 
        <geom name="wheel_rl_geom" type="cylinder" size="0.05 0.02" rgba="0.1 0.1 0.1 1" condim="3"/>
      </body>
      <body name="wheel_rr" pos="-0.3 -0.15 0">
        <joint name="wheel_rr_joint" type="hinge" axis="0 1 0" pos="0 0 0"/> 
        <geom name="wheel_rr_geom" type="cylinder" size="0.05 0.02" rgba="0.1 0.1 0.1 1" condim="3"/>
      </body>
    </body>
  </worldbody>
  <actuator>
    <motor joint="wheel_fl_joint" ctrlrange="-5 5" gear="30"/> 
    <motor joint="wheel_fr_joint" ctrlrange="-5 5" gear="30"/> 
    <motor joint="wheel_rl_joint" ctrlrange="-5 5" gear="30"/> 
    <motor joint="wheel_rr_joint" ctrlrange="-5 5" gear="30"/>
  </actuator>
</mujoco>
