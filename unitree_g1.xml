unitree_g1.xml
<?xml version="1.0" encoding="utf-8"?>
<mujoco model="unitree_g1">
    <compiler angle="degree" coordinate="local"/>
    <option timestep="0.002" gravity="0 0 -9.81"/>

    <!-- Default material -->
    <default>
        <geom type="mesh" contype="1" conaffinity="1" material="geom_mat"/>
        <joint type="hinge" limited="true" range="-180 180"/>
        <actuator>
            <motor gear="100" ctrlrange="-5 5" ctrllimited="true"/>
        </actuator>
    </default>

    <asset>
        <material name="geom_mat" rgba="0.8 0.8 0.8 1"/>
        <!-- Meshes (placeholders, actual STL files should be bundled) -->
        <mesh name="pelvis_mesh" file="meshes/pelvis.stl"/>
        <mesh name="thigh_mesh"   file="meshes/thigh.stl"/>
        <mesh name="shin_mesh"    file="meshes/shin.stl"/>
        <mesh name="foot_mesh"    file="meshes/foot.stl"/>
        <!-- Add more meshes for waist, arms, hands as needed -->
    </asset>

    <!-- World -->
    <worldbody>
        <geom name="ground" type="plane" size="10 10 0.1" rgba="0.2 0.5 0.2 1"/>
        
        <!-- Pelvis (fixed by default) -->
        <body name="pelvis" pos="0 0 0.9">
            <geom name="pelvis_geom" mesh="pelvis_mesh"/>
            <!-- Uncomment the free joint to enable full-body dynamics -->
            <!-- <joint name="floating_base_joint" type="free" limited="false" actuatorfrclimited="false"/> -->
            
            <!-- Left leg -->
            <body name="l_thigh" pos="0.05 0.09 0">
                <joint name="l_hip_pitch" type="hinge" axis="0 1 0" range="-45 45"/>
                <geom name="l_thigh_geom" mesh="thigh_mesh"/>
                <body name="l_shin" pos="0 -0.4 0">
                    <joint name="l_knee" type="hinge" axis="0 1 0" range="0 130"/>
                    <geom name="l_shin_geom" mesh="shin_mesh"/>
                    <body name="l_foot" pos="0 -0.4 0">
                        <joint name="l_ankle" type="hinge" axis="0 1 0" range="-30 30"/>
                        <geom name="l_foot_geom" mesh="foot_mesh"/>
                    </body>
                </body>
            </body>

            <!-- Right leg -->
            <body name="r_thigh" pos="-0.05 0.09 0">
                <joint name="r_hip_pitch" type="hinge" axis="0 1 0" range="-45 45"/>
                <geom name="r_thigh_geom" mesh="thigh_mesh"/>
                <body name="r_shin" pos="0 -0.4 0">
                    <joint name="r_knee" type="hinge" axis="0 1 0" range="0 130"/>
                    <geom name="r_shin_geom" mesh="shin_mesh"/>
                    <body name="r_foot" pos="0 -0.4 0">
                        <joint name="r_ankle" type="hinge" axis="0 1 0" range="-30 30"/>
                        <geom name="r_foot_geom" mesh="foot_mesh"/>
                    </body>
                </body>
            </body>

            <!-- Simple torso (waist) -->
            <body name="waist" pos="0 0 0.1">
                <joint name="waist_yaw" type="hinge" axis="0 0 1" range="-30 30"/>
                <geom type="box" size="0.12 0.06 0.04" rgba="0.6 0.6 0.6 1"/>
            </body>

            <!-- Arms (placeholder single segments) -->
            <body name="l_arm" pos="0.1 0 0.1">
                <joint name="l_shoulder_pitch" type="hinge" axis="0 1 0" range="-90 90"/>
                <geom type="capsule" fromto="0 0 0 0.2 0 0" size="0.03"/>
            </body>
            <body name="r_arm" pos="-0.1 0 0.1">
                <joint name="r_shoulder_pitch" type="hinge" axis="0 1 0" range="-90 90"/>
                <geom type="capsule" fromto="0 0 0 -0.2 0 0" size="0.03"/>
            </body>
        </body>
    </worldbody>

    <!-- Actuators -->
    <actuator>
        <motor joint="l_hip_pitch" name="act_l_hip_pitch"/>
        <motor joint="l_knee"       name="act_l_knee"/>
        <motor joint="l_ankle"      name="act_l_ankle"/>
        <motor joint="r_hip_pitch" name="act_r_hip_pitch"/>
        <motor joint="r_knee"       name="act_r_knee"/>
        <motor joint="r_ankle"      name="act_r_ankle"/>
        <motor joint="waist_yaw"    name="act_waist_yaw"/>
        <motor joint="l_shoulder_pitch" name="act_l_shoulder"/>
        <motor joint="r_shoulder_pitch" name="act_r_shoulder"/>
    </actuator>
</mujoco>